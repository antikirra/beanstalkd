FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libc6-dev make valgrind python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY . .

# ASan build (memory safety)
RUN make clean && make \
    CFLAGS="-O2 -g -fsanitize=address -fno-omit-frame-pointer" \
    LDFLAGS="-fsanitize=address" \
    && cp beanstalkd /usr/local/bin/beanstalkd-asan

# Debug build for Valgrind (ASan and Valgrind are incompatible)
RUN make clean && make \
    CFLAGS="-O0 -g3" \
    && cp beanstalkd /usr/local/bin/beanstalkd-debug

COPY test/loadtest.sh /loadtest.sh
RUN chmod +x /loadtest.sh

ENTRYPOINT ["/loadtest.sh"]
